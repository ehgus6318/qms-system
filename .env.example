# ─────────────────────────────────────────────────────────────────────────────
# .env.example  —  QMS/DCC 시스템 환경변수 예시
# 실제 .env 파일로 복사 후 값을 채워서 사용하세요
# .env 파일은 절대 Git에 커밋하지 마세요! (.gitignore에 등록됨)
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL 연결 문자열 ────────────────────────────────────────────────────
# 형식: postgresql://USER:PASSWORD@HOST:PORT/DATABASE?schema=SCHEMA
#
# 로컬 개발 (Docker PostgreSQL):
DATABASE_URL="postgresql://qms_user:qms_password@localhost:5432/qms_db?schema=public"
#
# 로컬 개발 (직접 설치 PostgreSQL):
# DATABASE_URL="postgresql://postgres:password@localhost:5432/qms_development?schema=public"
#
# 운영 환경 (예: Supabase):
# DATABASE_URL="postgresql://postgres:[YOUR-PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"
#
# 운영 환경 (예: AWS RDS):
# DATABASE_URL="postgresql://admin:password@qms-db.xxxx.ap-northeast-2.rds.amazonaws.com:5432/qms"

# ── NextAuth (향후 실제 인증 연동 시) ────────────────────────────────────────
# NEXTAUTH_SECRET="your-random-secret-key-here"
# NEXTAUTH_URL="http://localhost:3000"

# ── 파일 스토리지 (향후 S3/로컬 파일 업로드 연동 시) ───────────────────────
# AWS_REGION="ap-northeast-2"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"
# AWS_S3_BUCKET="qms-documents-bucket"
#
# 또는 로컬 스토리지:
# FILE_UPLOAD_DIR="./uploads"
# FILE_MAX_SIZE_MB="50"

# ── 이메일 알림 (향후 Nodemailer/SendGrid 연동 시) ───────────────────────────
# SMTP_HOST="smtp.example.com"
# SMTP_PORT="587"
# SMTP_USER="noreply@dh2.co.kr"
# SMTP_PASSWORD="your-smtp-password"
# EMAIL_FROM="QMS 품질관리시스템 <noreply@dh2.co.kr>"

# ── 앱 설정 ──────────────────────────────────────────────────────────────────
NODE_ENV="development"
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
# NEXT_PUBLIC_APP_NAME="QMS 품질관리시스템"
